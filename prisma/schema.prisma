// prisma/schema.prisma — CoreDXI 데이터베이스 스키마
//
// Admin: 관리자 계정 (이메일+비밀번호, 역할)
// User: 일반 고객 (OAuth + 이메일 가입) — NextAuth PrismaAdapter 대상
//
// ── 변경 이력 ──────────────────────────────────────────────────────
// v0.5  2026-05-15  Admin / User 모델 분리
// v0.4  2026-05-14  관리자 이메일+비밀번호 로그인용 필드 추가
// v0.3  2026-05-14  Supabase(PostgreSQL)로 전환
// v0.1  2026-05-14  최초 생성
// ────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  EDITOR
  VIEWER
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
}

// =====================================================
// Admin — 관리자 전용 (OAuth 없음)
// =====================================================
model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================================================
// User — 일반 고객 (NextAuth PrismaAdapter)
// =====================================================
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =====================================================
// Portfolio — 홍보팀 성공사례(포트폴리오) CMS
// =====================================================
model Portfolio {
  id           String   @id @default(cuid())
  title        String
  clientName   String
  thumbnailUrl String
  videoUrl     String?
  content      String   @db.Text
  metrics      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// =====================================================
// BlogPost — 홍보팀 블로그 (BlockNote JSON 본문)
// =====================================================
model BlogPost {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  excerpt     String?        @db.Text
  content     Json
  category    String
  status      BlogPostStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status])
  @@index([publishedAt])
}

// =====================================================
// OtpCode — 회원가입 이메일 6자리 인증 (5분 유효)
// =====================================================
model OtpCode {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}
