# =====================================================
# CoreDXI 환경 변수 설정 예시 파일
# 실제 값은 .env 파일에 넣으세요 (.env는 .gitignore에 포함되어 커밋되지 않습니다).
# =====================================================

# Supabase PostgreSQL — 커넥션 풀링 (런타임 쿼리용, pgbouncer, 포트 6543)
# [YOUR-PASSWORD] 부분을 Supabase 대시보드의 실제 DB 비밀번호로 교체하세요.
DATABASE_URL=

# Supabase PostgreSQL — 직접 연결 (마이그레이션 전용, 포트 5432)
DIRECT_URL=

# Google OAuth 설정
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth 필수 설정
# 로컬 개발 중일 때는 localhost, 배포 시에는 실제 도메인을 넣습니다.
NEXTAUTH_URL=http://localhost:3100
# 32자 이상의 무작위 문자열 (예: openssl rand -base64 32)
NEXTAUTH_SECRET=

RESEND_API_KEY=

# Kakao Login
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Naver Login
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Auth.js(NextAuth v5) 필수 설정 — NEXTAUTH_*와 동일한 값을 사용
AUTH_URL=http://localhost:3100
AUTH_SECRET=

# Supabase Storage (블로그 이미지 — blog-images 버킷)
# 대시보드: Project Settings → API → Project URL / service_role (secret)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google Analytics (gtag.js)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Analytics Data API (관리자 대시보드)
# 속성 ID: GA4 관리 → 속성 설정 → 속성 ID (숫자, G- 로 시작하는 측정 ID와 다름)
GA4_PROPERTY_ID=
# Vercel 등: 서비스 계정 JSON 전체를 한 줄로 붙여넣기
GA4_SERVICE_ACCOUNT_JSON=
# 로컬: secrets/ga4-service-account.json 경로 (위 JSON 변수가 있으면 무시됨)
GA4_SERVICE_ACCOUNT_PATH=

# Notion 연동 — 현재는 git post-commit 훅의 개발 워크플로 기록용으로만 사용
NOTION_TOKEN=
NOTION_PROJECTS_DB_ID=
NOTION_DOCUMENTS_DB_ID=
NOTION_TASKS_DB_ID=
NOTION_BUGTRACKER_DB_ID=
NOTION_DEPLOYMENTLOG_DB_ID=
NOTION_PORTFOLIO_DB_ID=
NOTION_TEMPLATESTOOLS_DB_ID=
# Git post-commit 훅용 — CoreDXI-Web Projects 페이지 ID
NOTION_PROJECT_PAGE_ID=
# (선택) 커밋 시 Tasks '사용 도구'에 기록할 값: Claude Code | Cursor | 기타
# VIBE_CODING_TOOL=

# (선택) /setup 최초 관리자 등록 시 추가 확인 토큰 — 미설정 시 확인 절차 생략
# SETUP_SECRET=

# (선택) Playwright E2E 관리자 로그인/블로그 발행 테스트 활성화용
# 설정하지 않으면 해당 테스트는 자동으로 skip됩니다.
# E2E_ADMIN_EMAIL=
# E2E_ADMIN_PASSWORD=
